# ─────────────────────────────────────────────────────────────────
# TeraBot 2.0 — Environment Configuration
# Copy this file to .env and fill in your values.
# The database section is auto-filled by start.sh if left blank.
# ─────────────────────────────────────────────────────────────────


# ── Required ──────────────────────────────────────────────────────

# Both values are found at: discord.com/developers/applications
# → Select your app → General Information (Client ID) / Bot (Token)

# Application / Client ID
DISCORD_CLIENT_ID=

# Bot Token
DISCORD_BOT_TOKEN=


# ── Database (auto-filled by start.sh) ───────────────────────────

DATABASE_URL=
PGHOST=localhost
PGPORT=5432
PGUSER=
PGPASSWORD=
PGDATABASE=discord_bot


# ── Stream Notifications (optional) ──────────────────────────────

# Twitch — https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# YouTube — https://console.cloud.google.com → YouTube Data API v3
YOUTUBE_API_KEY=


# ── Games Command (optional) ─────────────────────────────────────

# RAWG — https://rawg.io/apidocs
RAWG_API_KEY=

# IGDB — https://api-docs.igdb.com (requires Twitch app above)
IGDB_CLIENT_ID=
IGDB_ACCESS_TOKEN=


# ── Server ────────────────────────────────────────────────────────

NODE_ENV=production
PORT=5000

# Log level: debug | info | warn | error
LOG_LEVEL=info
